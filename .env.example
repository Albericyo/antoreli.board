# Base de données MySQL
# Copier ce fichier en .env et adapter les valeurs.
# Fichier à la racine du projet : antoreli/.env

DB_HOST=localhost
DB_NAME=shooting_board
DB_USER=root
DB_PASS=

# Optionnel
# DB_CHARSET=utf8mb4

# En cas d'erreur 500 : mettre APP_DEBUG=1 pour afficher le message d'erreur (à désactiver en prod).
# APP_DEBUG=0

# Utilisateur unique (connexion) : défini ici, plus de table users en base.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optionnel : si défini, le mot de passe de connexion est vérifié avec password_verify()
# (générer avec : php -r "echo password_hash('votre_mot_de_passe', PASSWORD_DEFAULT);")
# ADMIN_PASSWORD_HASH=

# Taille max d’upload vidéo en Mo (défaut 4096 = 4 Go). Pour vidéos de plusieurs Go.
# Sur Hostinger : créer .user.ini avec upload_max_filesize, post_max_size et max_execution_time.
# MAX_UPLOAD_MB=4096